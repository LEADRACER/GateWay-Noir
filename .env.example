# Database (Direct — for migrations + queries)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Database (Pooled — for serverless deployments)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].pooler.supabase.com:5432/postgres"

# Supabase Auth / Storage (anon key — safe for client)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon_public_key]"

# Supabase Service Role (admin operations — KEEP SECRET, server-only)
SUPABASE_SERVICE_ROLE_KEY="[service_role_key]"

# Site URL (for auth redirects)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Upload password for badge evidence (optional)
UPLOAD_PASSWORD=""
